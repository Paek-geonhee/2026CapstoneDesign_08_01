# UE 바이너리 에셋 — git이 텍스트로 diff하지 않도록 설정
# (LFS 미사용: 파일이 크면 나중에 filter=lfs 추가)
*.uasset binary
*.umap   binary

# 바이너리 라이브러리 (Embree4 등)
*.dll    binary
*.lib    binary
*.pdb    binary
*.exe    binary

# 이미지
*.png    binary
*.jpg    binary
*.jpeg   binary
*.tga    binary
*.bmp    binary
*.exr    binary
*.hdr    binary

# 줄 끝 통일 (소스 코드)
*.cs     text eol=crlf
*.cpp    text eol=crlf
*.h      text eol=crlf
*.md     text eol=lf
*.json   text eol=lf
*.ini    text eol=crlf
